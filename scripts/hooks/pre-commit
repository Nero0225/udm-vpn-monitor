#!/bin/bash
#
# Pre-commit hook for UDM VPN Monitor
# Runs linting, formatting checks, and regenerates the install package
#
# This ensures code quality and that the installer package is always up-to-date
# with the current codebase when committing changes.
#
# Environment variables:
#   SKIP_DOC_CHECKS: If set to any value, skips documentation checks only.
#                    Other checks (linting, formatting, package generation) still run.
#                    Example: SKIP_DOC_CHECKS=1 git commit -m "message"

set -euo pipefail

# Get the repository root directory with explicit error handling
REPO_ROOT=""
if ! REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"; then
	echo "Error: Not in a git repository or git command failed" >&2
	exit 1
fi

if [[ -z "$REPO_ROOT" ]] || [[ ! -d "$REPO_ROOT" ]]; then
	echo "Error: Could not determine repository root directory" >&2
	exit 1
fi

cd "$REPO_ROOT"

# Find a command in PATH or common installation locations
#
# Searches for a command in multiple locations to handle git hooks that run
# with minimal environment variables. Checks current PATH first, then standard
# system paths (/usr/bin, /usr/local/bin, /bin), and finally Homebrew paths.
# This ensures development tools are found even when PATH is not fully set.
#
# Arguments:
#   $1: Name of the command to find (e.g., "shfmt", "shellcheck")
#
# Returns:
#   0: Command found (prints full path to stdout)
#   1: Command not found in any checked location
#
# Output:
#   Prints full path to command if found (e.g., "/usr/bin/shfmt")
#
# Side effects:
#   None
#
# Examples:
#   if SHFMT_CMD=$(find_command shfmt); then
#       "$SHFMT_CMD" -w file.sh
#   fi
#
#   if ! SHELLCHECK_CMD=$(find_command shellcheck); then
#       echo "shellcheck not found"
#   fi
#
# Note:
#   Uses command -v for PATH checking (most reliable method)
#   Checks system paths for apt-installed tools
#   Checks common Homebrew locations (Linux and macOS)
#   Only checks executable files (not just presence of file)
#   Git hooks run with minimal environment, so PATH may not include all locations
find_command() {
	local cmd="$1"

	# First check if command is in PATH (works for apt-installed tools if PATH includes system paths)
	if command -v "$cmd" >/dev/null 2>&1; then
		command -v "$cmd"
		return 0
	fi

	# Check standard system paths (for apt-installed tools)
	local system_paths=(
		"/usr/bin"
		"/usr/local/bin"
		"/bin"
	)

	for sys_path in "${system_paths[@]}"; do
		if [[ -x "${sys_path}/${cmd}" ]]; then
			echo "${sys_path}/${cmd}"
			return 0
		fi
	done

	# Check common Homebrew locations (for Homebrew-installed tools)
	local brew_paths=(
		"/home/linuxbrew/.linuxbrew/bin" # Linux Homebrew (default)
		"$HOME/.linuxbrew/bin"           # Linux Homebrew (user install)
		"/opt/homebrew/bin"              # macOS Homebrew (Apple Silicon)
	)

	for brew_path in "${brew_paths[@]}"; do
		if [[ -x "${brew_path}/${cmd}" ]]; then
			echo "${brew_path}/${cmd}"
			return 0
		fi
	done

	return 1
}

# Get list of staged shell script files
mapfile -t STAGED_SH_FILES < <(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(sh)$' || true)

# Run linting and formatting checks if there are staged shell files
if [[ ${#STAGED_SH_FILES[@]} -gt 0 ]]; then
	echo "Running code quality checks on ${#STAGED_SH_FILES[@]} staged shell script(s)..."

	# Find ShellCheck
	SHELLCHECK_CMD=""
	if ! SHELLCHECK_CMD=$(find_command shellcheck); then
		echo "Warning: ShellCheck not found. Install it to enable linting:" >&2
		echo "  macOS: brew install shellcheck" >&2
		echo "  Linux: sudo apt-get install shellcheck" >&2
		echo "  See DEVELOPER.md for more installation options" >&2
	else
		# Run ShellCheck on staged files
		echo "Running ShellCheck..."
		if ! "$SHELLCHECK_CMD" --severity=error "${STAGED_SH_FILES[@]}"; then
			echo "Error: ShellCheck found errors. Please fix them before committing." >&2
			echo "Run 'shellcheck *.sh lib/*.sh tests/*.sh' to see all issues." >&2
			exit 1
		fi
	fi

	# Find shfmt
	SHFMT_CMD=""
	if ! SHFMT_CMD=$(find_command shfmt); then
		echo "Warning: shfmt not found. Install it to enable formatting checks:" >&2
		echo "  macOS: brew install shfmt" >&2
		echo "  Linux: sudo snap install shfmt" >&2
		echo "  See DEVELOPER.md for more installation options" >&2
	else
		# Check formatting with shfmt
		echo "Checking code formatting with shfmt..."
		if ! "$SHFMT_CMD" -d "${STAGED_SH_FILES[@]}" >/dev/null 2>&1; then
			echo "Error: Code formatting issues detected." >&2
			echo "Please run 'shfmt -w ${STAGED_SH_FILES[*]}' to fix formatting." >&2
			exit 1
		fi
	fi

	# Check documentation standards (skip if SKIP_DOC_CHECKS is set)
	if [[ -z "${SKIP_DOC_CHECKS:-}" ]]; then
		DOC_CHECK_SCRIPT="${REPO_ROOT}/scripts/check-documentation.sh"
		if [[ -f "$DOC_CHECK_SCRIPT" ]] && [[ -x "$DOC_CHECK_SCRIPT" ]]; then
			echo "Checking function documentation standards..."
			if ! "$DOC_CHECK_SCRIPT"; then
				echo "Error: Documentation check failed. Please fix documentation issues before committing." >&2
				exit 1
			fi
		else
			echo "Warning: Documentation checker script not found or not executable: $DOC_CHECK_SCRIPT" >&2
		fi
	else
		echo "Skipping documentation checks (SKIP_DOC_CHECKS is set)..."
	fi
fi

# Check if prepare_install_package.sh exists
if [[ ! -f "${REPO_ROOT}/scripts/prepare_install_package.sh" ]]; then
	echo "Error: prepare_install_package.sh not found" >&2
	exit 1
fi

# Check if prepare_install_package.sh is executable
if [[ ! -x "${REPO_ROOT}/scripts/prepare_install_package.sh" ]]; then
	chmod +x "${REPO_ROOT}/scripts/prepare_install_package.sh"
fi

echo "Running prepare_install_package.sh..."

# Run prepare_install_package.sh
if ! "${REPO_ROOT}/scripts/prepare_install_package.sh"; then
	echo "Error: prepare_install_package.sh failed" >&2
	exit 1
fi

# Check if the zip file was created
PACKAGE_FILE="${REPO_ROOT}/udm-vpn-monitor.zip"
if [[ ! -f "$PACKAGE_FILE" ]]; then
	echo "Error: Package file not created: $PACKAGE_FILE" >&2
	exit 1
fi

# Add the package file to the staging area
echo "Adding ${PACKAGE_FILE} to commit..."
git add "$PACKAGE_FILE"

echo "Pre-commit hook completed successfully."
